{
  "publisher": "DuckyMomo20012",
  "name": "status-bar-btn",
  "displayName": "status-bar-btn",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "description": "",
  "author": "DuckyMomo20012 <tienvinh.duong4@gmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/DuckyMomo20012",
  "homepage": "https://github.com/DuckyMomo20012/status-bar-btn#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/DuckyMomo20012/status-bar-btn"
  },
  "bugs": {
    "url": "https://github.com/DuckyMomo20012/status-bar-btn/issues"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/DuckyMomo20012"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/index.cjs",
  "icon": "res/icon.png",
  "files": [
    "LICENSE.md",
    "dist/*",
    "res/*"
  ],
  "engines": {
    "vscode": "^1.97.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "status-bar-btn.toggle",
        "title": "status-bar-btn: Toggle Status Bar Button"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Status Bar Button",
      "properties": {
        "status-bar-btn.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the status bar button."
        },
        "status-bar-btn.btns": {
          "type": "array",
          "default": [],
          "description": "An array of button configurations for the status bar.",
          "items": {
            "type": "object",
            "description": "Configuration for a single status bar button.",
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "description": "The identifier of this item. Falls back to extension ID if omitted."
              },
              "alignment": {
                "type": "string",
                "enum": [
                  "left",
                  "right"
                ],
                "default": "right",
                "description": "The alignment of this item in the status bar (Left or Right)."
              },
              "priority": {
                "type": "number",
                "description": "The priority of this item. Higher values push the item further to the left."
              },
              "name": {
                "type": "string",
                "description": "The descriptive name of the entry (e.g., 'Git Status'), visible in user settings."
              },
              "text": {
                "type": "string",
                "description": "The text to show. Supports octicons using the '$(icon-name)' syntax."
              },
              "tooltip": {
                "description": "The tooltip text displayed when hovering over this entry.",
                "anyOf": [
                  {
                    "type": "string",
                    "description": "Plain text tooltip."
                  },
                  {
                    "type": "object",
                    "description": "Markdown formatted string.",
                    "required": [
                      "value"
                    ],
                    "properties": {
                      "value": {
                        "type": "string"
                      },
                      "isTrusted": {
                        "type": "boolean"
                      },
                      "supportThemeIcons": {
                        "type": "boolean"
                      }
                    }
                  }
                ]
              },
              "color": {
                "description": "The foreground text/icon color for this entry.",
                "anyOf": [
                  {
                    "type": "string",
                    "description": "A traditional hex/color string or theme token identifier."
                  },
                  {
                    "type": "object",
                    "description": "A dedicated VS Code ThemeColor instance reference wrapper.",
                    "required": [
                      "id"
                    ],
                    "properties": {
                      "id": {
                        "type": "string"
                      }
                    }
                  }
                ]
              },
              "backgroundColor": {
                "type": "object",
                "description": "The background color for this entry. Officially supports 'statusBarItem.errorBackground' or 'statusBarItem.warningBackground'.",
                "required": [
                  "id"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "enum": [
                      "statusBarItem.errorBackground",
                      "statusBarItem.warningBackground"
                    ]
                  }
                }
              },
              "command": {
                "description": "The identifier string or complete Command object to run on click.",
                "anyOf": [
                  {
                    "type": "string",
                    "description": "The ID string of the command to execute."
                  },
                  {
                    "type": "object",
                    "description": "Full command declaration metadata block.",
                    "required": [
                      "command"
                    ],
                    "properties": {
                      "command": {
                        "type": "string"
                      },
                      "title": {
                        "type": "string"
                      },
                      "tooltip": {
                        "type": "string"
                      },
                      "arguments": {
                        "type": "array",
                        "items": {}
                      }
                    }
                  }
                ]
              },
              "accessibilityInformation": {
                "type": "object",
                "description": "Accessibility information used when a screen reader interacts with this item.",
                "required": [
                  "label"
                ],
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "role": {
                    "type": "string"
                  }
                }
              },
              "visible": {
                "type": "boolean",
                "description": "Whether the status bar item is visible",
                "default": true
              }
            },
            "required": [
              "text",
              "command"
            ]
          }
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --external vscode",
    "dev": "nr build --watch --sourcemap",
    "prepare": "nr update",
    "update": "vscode-ext-gen --output src/generated/meta.ts",
    "lint": "eslint .",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "nr build",
    "ext:package": "vsce package --no-dependencies",
    "ext:publish": "vsxpub --no-dependencies"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.1.0",
    "@antfu/ni": "30.2.0",
    "@types/node": "26.1.0",
    "@types/vscode": "^1.97.0",
    "@vscode/vsce": "3.9.2",
    "eslint": "9.39.4",
    "prettier": "^3.9.4",
    "reactive-vscode": "1.0.2",
    "taze": "19.14.1",
    "tsdown": "0.22.3",
    "typescript": "5.9.3",
    "vite": "8.1.3",
    "vitest": "4.1.9",
    "vscode-ext-gen": "1.6.0",
    "vsxpub": "0.1.4"
  }
}
